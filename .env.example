PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://cadence:cadence_dev@localhost:5432/cadence
POSTGRES_PASSWORD=cadence_dev

# Google Calendar OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-run-openssl-rand-hex-64

# Encryption
# Used for AES-256-GCM encryption of OAuth tokens at rest
# MUST be exactly 64 hex characters: openssl rand -hex 32
ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# CORS — comma-separated list of allowed origins
# Dev: http://localhost:5173 (Vite). Prod: your app + landing domains.
CORS_ORIGIN=http://localhost:5173

# Frontend URLs (set at build time for SvelteKit packages)
# PUBLIC_API_URL  — API base for the web app (omit for same-origin / dev proxy)
# PUBLIC_APP_URL  — App URL for landing site login/signup links
#
# Example production values:
#   PUBLIC_API_URL=https://api.cadence.dev/api
#   VITE_APP_URL=https://app.cadence.dev       (landing package)
#   CORS_ORIGIN=https://app.cadence.dev,https://cadence.dev

# SMTP (email verification, password reset)
# Leave empty to log emails to console in development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cadence <noreply@cadence.app>

# Frontend URL (used for links in emails, CORS, etc.)
FRONTEND_URL=http://localhost:5173

# Reverse proxy trust — set to 1 when behind a single reverse proxy (nginx,
# Cloudflare, etc.) so Express reads the real client IP from X-Forwarded-For.
# Required for rate limiting to work correctly in production.
# Set to the number of proxies in the chain, or "loopback" for local proxies.
TRUST_PROXY=

# Google Calendar push notifications (production only — requires public HTTPS URL)
# When set, uses webhook push notifications instead of polling
# WEBHOOK_BASE_URL=https://api.yourdomain.com

# Node environment (production, development, test)
NODE_ENV=development
